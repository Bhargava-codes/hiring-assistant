# Copy to .env and fill in. .env is git-ignored.

# OpenRouter (OpenAI-compatible). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Models (both swappable here). Defaults match the PRD/build spec.
INTAKE_MODEL=anthropic/claude-sonnet-4.6
EXTRACT_MODEL=anthropic/claude-haiku-4.5

# Optional: OpenRouter attribution headers
OPENROUTER_APP_URL=http://localhost:8000
OPENROUTER_APP_NAME=Contract HRMS

# SQLite location (defaults to ./data/hrms.db)
DATABASE_URL=sqlite:///./data/hrms.db
